# Backend Test Dockerfile - Lightweight for quick K8s testing
# Only includes essential dependencies, not full production setup

FROM python:3.13-slim

WORKDIR /app

# Install only core FastAPI dependencies (not the entire suite)
RUN pip install --no-cache-dir \
    fastapi==0.128.0 \
    uvicorn==0.40.0 \
    pydantic-settings==2.12.0 \
    httpx>=0.28.0  # for health check

# Copy just the main application (no full backend code, just enough to start)
COPY backend/main.py .
COPY backend/config.py .
COPY backend/logging_config.py .
COPY backend/models/ ./models/
COPY backend/middleware/ ./middleware/

EXPOSE 8000

# Health check using Python instead of curl
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD python -c "import httpx; httpx.get('http://localhost:8000/health')" || exit 1

# Start with uvicorn
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
